# Credentials (never commit these)
.credentials*
*.json

# Exceptions — rollback backups for documented config mitigations
!docs/backups/*.json
# Exceptions — provider-rules lint data for AGENTS.md mirror tooling
!docs/provider-rules/*.json

# Claude Code session scratch — per-workdir, not source
.claude/
# Cycle state: ignore everything in .cycle/ except LEARNINGS.md and .gitignore
.cycle/*
!.cycle/LEARNINGS.md
!.cycle/.gitignore

# OS
.DS_Store
Thumbs.db

# Editor
*.swp
*.swo
*~
.vscode/
.idea/

# Python
__pycache__/
.pytest_cache/
